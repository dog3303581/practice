"""
案例--基于面向对象的编程思想完成如下系统开发
某社区图书馆需要开发一个简单的图书管理系统。系统需要支持会员登录、图书借阅、图书归还等功能。系统中有两种类型的会员:普通会员和VIP会员，他们的借书权限不同。你需要使用面向对象编程的思想，设计并实现这个图书管理系统。
核心功能:
    1.会员登录:会员通过卡号和密码登录系统
    2.借书:会员可以借阅库存中有余量的图书
    3.还书:会员可以归还借阅的图书
    4.查看我的借阅:展示当前会员已经借阅的图书列表
    5.退出系统
借阅规则:
    1.普通会员最多可借3本
    2.VIP会员最多可借6+VIP等级本(VIP等级，默认为1)
注意:
    1.登录成功(卡号和密码均正确)后，才可以访问该系统
    2.图书库存不足，或当前会员借书数量达到最大借书数量，不能再借新书
"""

# 核心系统面板
"""
核心功能:
    1.会员登录:会员通过卡号和密码登录系统
    2.借书:会员可以借阅库存中有余量的图书
    3.还书:会员可以归还借阅的图书
    4.查看我的借阅:展示当前会员已经借阅的图书列表
    5.退出系统
"""
# 图书馆系统界面
def main_interface():
    print("""
    ======================  图书馆借阅系统   ======================
    # # # # # # # # # # #   1.会员登录      # # # # # # # # # # #
    # # # # # # # # # # #   2.借书         # # # # # # # # # # #
    # # # # # # # # # # #   3.还书         # # # # # # # # # # #
    # # # # # # # # # # #   4.查看我的借阅  # # # # # # # # # # #
    # # # # # # # # # # #   5.退出系统     # # # # # # # # # # #
    ============================================================
    """)
    choice = int(input("请选择要执行操作，输入1-5: "))
    return choice

# 图书管理系统
class Library_System:
    # 初始化书籍列表,会员列表等图书馆系统信息
    def __init__(self):
        self.book_list = ["肖申克的救赎", "三国演义", "水浒传", "红楼梦", "金瓶梅", "三毛历险记", "随机漫步的傻瓜", "穷查理", "大数据教学"]
        self.member_list = {"260001": {"name": "张三", "password": "123456", "is_vip": False, "vip_level": 0, "borrowed_book_list": ["哈利波特"]},
                            "260002": {"name": "李四", "password": "665643", "is_vip": True, "vip_level": 1, "borrowed_book_list": []},
                            "260003": {"name": "王五", "password": "467832", "is_vip": True, "vip_level": 3, "borrowed_book_list": ["西游记", "三国演义"]},
                            "260004": {"name": "赵六", "password": "562241", "is_vip": False, "vip_level": 0, "borrowed_book_list": []}
                            }
# # 验证会员账号获取
#     def num_lib(self):
#         print("会员账号为: ", list(self.member_list.keys()))
#     # 会员登录

# 验证密码获取
#     def num_pwd(self):
