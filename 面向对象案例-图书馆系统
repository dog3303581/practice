    # 会员登录功能
    """
    会员通过卡号(self.member_list里的key)和密码((self.member_list里的password的value值)登录系统
    判断卡号密码是否正确,不正确就提示"卡号或密码错误",然后返回登录界面
    """
    def login(self):
        print("""======================  登录界面   ======================""")
        num = str(input("请输入会员卡号:"))
        password = input("请输入会员密码: ")
        if num in self.member_list and self.member_list[num]["password"] == password:
            print(f"""==================  登录成功！欢迎 {self.member_list[num]['name']}  ==================""")
            return num  # 返回登录成功的会员编号
        else:
            print("卡号或密码错误")
            return None  # 登录失败返回None

    # 借书功能
    def borrow_book(self, current_user_id):
        """
        如果是普通会员可以借阅库存中图书, 总数量不能超过3本
        如果是VIP会员可以借阅库存中图书, 总数量最多可借6+VIP等级本
        如果不是会员,不能借书
        """
        bo_book_name = input("请输入要借阅的图书名称: ")
        current_user = self.member_list[current_user_id]

        if current_user["is_vip"]:
            max_books = 6 + current_user["vip_level"]
            print(f"您是VIP会员, 借阅数量最多可借{max_books}本")
            if len(current_user["borrowed_book_list"]) < max_books:
                if bo_book_name in self.book_list:
                    current_user["borrowed_book_list"].append(bo_book_name)
                    # 原书库减少这本书
                    self.book_list.remove(bo_book_name)
                    print("借阅成功")
                else:
                    print("借阅失败, 没有这本书, 或书已被借出")
            else:
                print("借阅失败,您的借出数量已经达到最大值")
        else:
            max_books = 3
            print(f"您只是普通会员, 借阅数量最多可借{max_books}本")
            if len(current_user["borrowed_book_list"]) < max_books:
                if bo_book_name in self.book_list:
                    current_user["borrowed_book_list"].append(bo_book_name)
                    # 原书库减少这本书
                    self.book_list.remove(bo_book_name)
                    print("借阅成功")
                else:
                    print("借阅失败, 没有这本书, 或书已被借出")
            else:
                print("借阅失败,您的借出数量已经达到最大值")

    # 还书功能
    def return_book(self, current_user_id):
        re_book_name = input("请输入要还书的图书名称: ")
        current_user = self.member_list[current_user_id]

        if re_book_name in current_user["borrowed_book_list"]:
            current_user["borrowed_book_list"].remove(re_book_name)
            self.book_list.append(re_book_name)
            print("还书成功")
        else:
            print("还书失败, 您没有借过这本书")

    # 查看我的借阅:展示当前会员已经借阅的图书列表
    def show_my_borrowed_book(self, current_user_id):
        current_user = self.member_list[current_user_id]
        print(f"{current_user['name']} 已经借阅的图书列表为: {current_user['borrowed_book_list']}")

    # 退出系统
    def exit_system(self):
        print("退出系统")

if __name__ == '__main__':
    """
    初始化图书馆系统数据
    启动图书馆系统界面
        只有登录成功才能启用其他功能,用match来实现
    """
    ls = Library_System()

    # 必须先登录
    current_user_id = None
    while current_user_id is None:
        print("""请先登录系统!""")
        current_user_id = ls.login()

    # 登录成功后进入主循环
    while True:
        a = main_interface()

        match a:
            case 1:
                print("您已经登录成功,无需再次登录")

            case 2:
                ls.borrow_book(current_user_id)

            case 3:
                ls.return_book(current_user_id)

            case 4:
                ls.show_my_borrowed_book(current_user_id)

            case 5:
                ls.exit_system()
                print("感谢使用，再见！")
                break

            case _:
                print("请输入正确的选项")
